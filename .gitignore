# ── SQLite database ──────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*-wal
*-shm

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Virtual environments ─────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── Environment variables ────────────────────────────────────
.env
.env.*

# ── Logs ─────────────────────────────────────────────────────
*.log

# ── IDE / OS ─────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Test / coverage ──────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
pytest-cache-files-*/

# ── PyInstaller build output ─────────────────────────────────
# Keep: StudentManagementSystem.spec  (build config, should be committed)
build/
dist/
*.egg-info/

# ── NSIS compiled installer output ───────────────────────────
# Keep: installer.nsi  (source script, should be committed)
*-Setup.exe

# ── Temporary files ──────────────────────────────────────────
*.tmp
*.bak
.ipynb_checkpoints/
tempCodeRunnerFile.py

# ── Claude Code ───────────────────────────────────────────────
.claude/
